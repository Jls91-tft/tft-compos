# === Synapse — variables de entorno (ETAPA 2) ===
# Copia este archivo a .env  (cp .env.example .env)  y rellena los valores
# EN EL OTRO PC. El fichero .env NO se versiona (está en .gitignore).

# --- Riot API ---
# Consigue tu clave en https://developer.riotgames.com (es gratuita).
RIOT_API_KEY=RGAPI-PON-TU-CLAVE-AQUI
RIOT_REGION=europe
RIOT_PLATFORM=euw1
# Opcional: Riot ID por defecto para pruebas (formato Nombre#TAG)
DEFAULT_RIOT_ID=

# --- IA: proveedor (ollama local | groq | openrouter) ---
LLM_PROVIDER=ollama
# Ollama (local, privado)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
# Groq (gratis): clave en https://console.groq.com
#   llama-3.1-8b-instant   = rápido, mucho volumen (14.4k req/día) pero análisis más flojo
#   llama-3.3-70b-versatile = MUCHA más calidad de coaching (1.000 req/día, más lento) ← recomendado
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OpenRouter (gratis): clave en https://openrouter.ai — acceso a modelos grandes con razonamiento.
#   Copia el slug EXACTO desde https://openrouter.ai/models (ej. DeepSeek V4 Flash, Nemotron).
#   Sin saldo: ~50 req/día y 20 RPM; con 10$ de saldo sube a ~1.000 req/día.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
# Temperatura del LLM (0.0 = más determinista, 1.0 = más creativo)
LLM_TEMPERATURE=0.4

# --- Aplicación ---
# true  = la API responde con datos de ejemplo (útil sin clave de Riot todavía)
# false = usa Riot API + Ollama reales
USE_MOCK=true

# --- Despliegue gratuito (docker-compose.prod.yml) ---
# Token del túnel de Cloudflare (Zero Trust > Networks > Tunnels). Da HTTPS sin abrir puertos.
TUNNEL_TOKEN=

# --- Worker de meta (opcional: docker-compose --profile meta) ---
# Genera estadísticas REALES (winrate/uso de unidades, ítems, augments) agregando
# partidas del ladder Challenger vía Riot API. Requiere RIOT_API_KEY de producción.
META_REFRESH_SECONDS=43200    # cada cuánto refresca (43200 = 12 h)
META_SAMPLE_PLAYERS=40        # jugadores del ladder a muestrear (ojo rate limits)
META_MATCHES_PER_PLAYER=8     # partidas por jugador
