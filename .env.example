# === Synapse — variables de entorno (ETAPA 2) ===
# Copia este archivo a .env  (cp .env.example .env)  y rellena los valores
# EN EL OTRO PC. El fichero .env NO se versiona (está en .gitignore).

# --- Riot API ---
# Consigue tu clave en https://developer.riotgames.com (es gratuita).
RIOT_API_KEY=RGAPI-PON-TU-CLAVE-AQUI
RIOT_REGION=europe
RIOT_PLATFORM=euw1
# Opcional: Riot ID por defecto para pruebas (formato Nombre#TAG)
DEFAULT_RIOT_ID=

# --- IA: proveedor (ollama local | groq API) ---
LLM_PROVIDER=ollama
# Ollama (local, privado)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
# Groq (gratis y rápido, recomendado para la beta): clave en https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Aplicación ---
# true  = la API responde con datos de ejemplo (útil sin clave de Riot todavía)
# false = usa Riot API + Ollama reales
USE_MOCK=true

# --- Despliegue gratuito (docker-compose.prod.yml) ---
# Token del túnel de Cloudflare (Zero Trust > Networks > Tunnels). Da HTTPS sin abrir puertos.
TUNNEL_TOKEN=
